@model SimbprMvc.Models.ViewModels.ProyectosListViewModel
@{
    ViewData["Title"] = "Proyectos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Gestión de Proyectos</h1>
        <p class="text-muted mb-0 small">Administra los proyectos de simulación de pozos</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16">
            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
        </svg>
        Nuevo proyecto
    </a>
</div>

@if (!Model.Proyectos.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🛢</div>
        <h5 class="mt-3">No hay proyectos</h5>
        <p class="small">Crea tu primer proyecto para comenzar a simular.</p>
        <a asp-action="Create" class="btn btn-primary btn-sm">Crear proyecto</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var p in Model.Proyectos)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex align-items-start gap-3">
                            <!-- Avatar -->
                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-secondary"
                                 style="width:44px;height:44px;min-width:44px;background:#dbeafe;font-size:.95rem">
                                @p.Iniciales
                            </div>
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="mb-0 fw-semibold text-truncate">@p.Nombre</h6>
                                <div class="text-muted small">@p.Usuario</div>
                            </div>
                            <!-- Status badge -->
                            <form asp-action="Toggle" asp-route-id="@p.Id" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm badge border-0 @p.EstadoBgColor @p.EstadoTextColor"
                                        style="cursor:pointer;font-size:.75rem"
                                        title="Cambiar estado">
                                    @p.Estado
                                </button>
                            </form>
                        </div>

                        <hr class="my-3" />

                        <dl class="row small mb-0">
                            <dt class="col-5 text-muted fw-normal">Cliente</dt>
                            <dd class="col-7 text-truncate mb-1">@p.Cliente</dd>
                            @if (!string.IsNullOrEmpty(p.Compania))
                            {
                                <dt class="col-5 text-muted fw-normal">Compañía</dt>
                                <dd class="col-7 text-truncate mb-1">@p.Compania</dd>
                            }
                            @if (!string.IsNullOrEmpty(p.Orden))
                            {
                                <dt class="col-5 text-muted fw-normal">Orden</dt>
                                <dd class="col-7 text-truncate mb-1">@p.Orden</dd>
                            }
                            <dt class="col-5 text-muted fw-normal">Fecha</dt>
                            <dd class="col-7 mb-0">@p.Fecha</dd>
                        </dl>
                    </div>

                    <div class="card-footer bg-transparent border-top d-flex gap-2 justify-content-end">
                        <a asp-controller="Simulacion" asp-action="Index" asp-route-proyectoId="@p.Id"
                           class="btn btn-sm btn-primary">
                            🔬 Simular
                        </a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">
                            Editar
                        </a>
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="m-0"
                              onsubmit="return confirm('¿Eliminar el proyecto &quot;@Html.Raw(p.Nombre.Replace("'", "\\'"))&quot;?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
