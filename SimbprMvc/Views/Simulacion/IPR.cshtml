@model SimbprMvc.Models.ViewModels.SimulacionIPRViewModel
@{
    ViewData["Title"] = $"IPR — {Model.ProyectoNombre}";
    var r = Model.Resultado;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-controller="Simulacion" asp-action="Index" asp-route-proyectoId="@Model.ProyectoId"
       class="btn btn-sm btn-outline-secondary">← Simulador</a>
    <h5 class="mb-0 fw-bold">📈 IPR Vogel — @Model.ProyectoNombre</h5>
</div>

<partial name="_IPRPanel" model="Model" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
