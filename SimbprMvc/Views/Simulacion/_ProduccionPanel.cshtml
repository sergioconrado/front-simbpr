@model SimbprMvc.Models.ViewModels.SimulacionProduccionViewModel
@{
    var r = Model.Resultado;
}

<div class="row g-4">
    <!-- Input form -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 fw-bold">Parámetros de Producción</h6>
            </div>
            <div class="card-body p-4">
                <form asp-controller="Simulacion" asp-action="Produccion"
                      asp-route-proyectoId="@Model.ProyectoId" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                    <input type="hidden" asp-for="ProyectoId" />

                    <div class="mb-3">
                        <label asp-for="Qt" class="form-label small fw-semibold"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Qt" class="form-control" type="number" step="any" min="0" />
                            <span class="input-group-text">bpd</span>
                        </div>
                        <span asp-validation-for="Qt" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Bsw" class="form-label small fw-semibold"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Bsw" class="form-control" type="number" step="any" min="0" max="100" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="Bsw" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Api" class="form-label small fw-semibold"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Api" class="form-control" type="number" step="any" min="0" />
                            <span class="input-group-text">°API</span>
                        </div>
                        <span asp-validation-for="Api" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Gor" class="form-label small fw-semibold"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Gor" class="form-control" type="number" step="any" min="0" />
                            <span class="input-group-text">scf/bbl</span>
                        </div>
                        <span asp-validation-for="Gor" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Bo" class="form-label small fw-semibold"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Bo" class="form-control" type="number" step="any" min="0" />
                            <span class="input-group-text">rb/stb</span>
                        </div>
                        <span asp-validation-for="Bo" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        Calcular &amp; Guardar
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Results -->
    <div class="col-lg-8">
        @if (r is not null)
        {
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-4">
                    <div class="card border-0 bg-success text-white text-center py-3 shadow-sm">
                        <div class="fw-bold fs-5">@r.Qo.ToString("F1")</div>
                        <div class="small">Qo (bpd)</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card border-0 bg-primary text-white text-center py-3 shadow-sm">
                        <div class="fw-bold fs-5">@r.Qw.ToString("F1")</div>
                        <div class="small">Qw (bpd)</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card border-0 bg-warning text-dark text-center py-3 shadow-sm">
                        <div class="fw-bold fs-5">@r.Qg.ToString("F3")</div>
                        <div class="small">Qg (Mscf/d)</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card border-0 bg-secondary text-white text-center py-3 shadow-sm">
                        <div class="fw-bold fs-5">@r.Densidad.ToString("F4")</div>
                        <div class="small">Densidad (g/cc)</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card border-0 bg-info text-white text-center py-3 shadow-sm">
                        <div class="fw-bold fs-5">@r.QReservorio.ToString("F1")</div>
                        <div class="small">Q yacimiento (rb/d)</div>
                    </div>
                </div>
            </div>

            <!-- Desglose table -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-2">
                    <h6 class="mb-0 small fw-bold">Desglose de Fluidos</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-striped table-bordered mb-0 small">
                        <thead class="table-dark">
                            <tr>
                                <th>Parámetro</th>
                                <th class="text-end">Valor</th>
                                <th>Unidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td>Caudal de aceite Qo</td><td class="text-end">@r.Qo.ToString("F2")</td><td>bpd</td></tr>
                            <tr><td>Caudal de agua Qw</td><td class="text-end">@r.Qw.ToString("F2")</td><td>bpd</td></tr>
                            <tr><td>Caudal de gas Qg</td><td class="text-end">@r.Qg.ToString("F4")</td><td>Mscf/d</td></tr>
                            <tr><td>Densidad del aceite</td><td class="text-end">@r.Densidad.ToString("F4")</td><td>g/cc</td></tr>
                            <tr><td>Caudal en yacimiento</td><td class="text-end">@r.QReservorio.ToString("F2")</td><td>rb/d</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <div style="font-size:3rem">🧪</div>
                <p class="mt-2">Ingresa los parámetros y presiona <strong>Calcular</strong>.</p>
            </div>
        }
    </div>
</div>
